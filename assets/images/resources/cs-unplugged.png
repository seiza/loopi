    <div id="educator-jumbotron" class="jumbotron jumbotron-fluid">
        <div class="container">
            <h1 class="text-center text-white text-shadow">
                Computer Science<br>without a computer
            </h1>
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8 text-center">
                    <p class="lead text-light text-wrap text-shadow">
                        CS Unplugged is a collection of free teaching material that teaches Computer Science through engaging games and puzzles that use cards, string, crayons and lots of running around.
                    </p>
                    
                        <a class="btn btn-at-a-distance text-wrap mb-4" role="button" href="/en/at-a-distance/">
                            <strong>New!</strong> Adapted CS Unplugged lessons for teaching students and educators online
                        </a>
                    
                </div>
            </div>
        </div>
    </div>

