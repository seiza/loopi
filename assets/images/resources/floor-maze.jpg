			.wp-block-media-text.is-image-fill-element > .wp-block-media-text__media img {

  height: 100% !important;
}

.wp-block-video video{
	width: 100%;
	height: auto;
}

figure.wp-block-image {
    display: flex
;
    justify-content: center;
    flex-direction: column;
}

.wp-block-columns-is-layout-flex{
	gap: 0;
}
.wp-block-columns{
	align-items: center;
}

.wp-block-kadence-posts .loop-entry .post-thumbnail {
    display: block;
    height: 0;
    padding-bottom: 66.67%;
		overflow: visible;
    position: relative;
    margin: auto 0;
}

.kb-buttons-wrap{
	display: block;
}


.wp-block-kadence-posts .loop-entry .post-thumbnail .post-thumbnail-inner {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
		bottom: auto;
    left: 0;
    right: 0;
}


.wp-block-kadence-posts .loop-entry {
    box-shadow: none;
    border-radius: .25rem;
}

.entry-title, .entry-title a {
	color: var(--Colour-Navy, #191238) !important;

/* Heading/H3 */
font-size: var(--Type-Font-size-Heading-H3, 24px);
font-style: normal;
font-weight: 500;
line-height: var(--Type-Font-size-Heading-H3, 24px); /* 100% */
}

.border-classroom, .author-podcast .kb-post-list-item {

    -webkit-box-shadow: 12px 12px #7635db;
    box-shadow: 12px 12px #D4F3FF;
    z-index: 20;
}

.border-corridor, .corridor-podcast .kb-post-list-item {

    -webkit-box-shadow: 12px 12px #FFEFCE;
    box-shadow: 12px 12px #FFEFCE;
    z-index: 20;
}


.border-loop, .loop-podcast .kb-post-list-item {

    -webkit-box-shadow: 12px 12px #EBEBFF;
    box-shadow: 12px 12px #EBEBFF;
    z-index: 20;
}

.fw-normal{
	font-weight: 500;
}
.podcast-container {
	margin-top: 24px !important;
	padding: 0 24px !important;
	background-color: white;
    overflow: hidden;
    max-height: 1000px;
    transition: max-height 0.5s ease-in-out;

	border-radius: 8px 8px 8px 8px;
	-webkit-box-shadow: 4px 4px 20px 0px rgba(0,0,0,0.25); 
box-shadow: 4px 4px 20px 0px rgba(0,0,0,0.25);
	
}

.fw-300 {
	font-weight: 300 !important;
}

.fw-500 {
	font-weight: 500 !important;
}

.podcast-main .kb-post-list-item:not(:last-child) {
  border-bottom: 3px solid #C7D0E1;
}

.pc-container-no-margin{
	margin: 0;
}

.podcast-container.collapsed {
    max-height: 0;
		
}

@media screen and (min-width: 768px) {
    .wp-block-kadence-posts.grid-lg-col-1.item-image-style-beside article.loop-entry.has-post-thumbnail:not(.kb-post-no-image) {
        display: grid;
        grid-template-columns: minmax(0, .4fr) minmax(0, 2fr);
    }
}

.podcast-main .wp-block-kadence-posts.grid-cols {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    column-gap: 0;
    row-gap: 0;
}
.wp-block-kadence-posts .loop-entry {
    box-shadow: none;
    border-radius:  0;
}



.podcast-main .wp-block-kadence-posts .loop-entry .post-thumbnail img {
    flex: 1;
    height: auto;
    object-fit: cover;
    width: 150px;
    margin: auto;
	
}

.podcast-archive .wp-block-kadence-posts .loop-entry{
	padding: 20px;
	
}

.podcast-archive .wp-block-kadence-posts .entry-title a{
	font-weight: 500;
	font-size: 24px;
	color: #191238;
}

.podcast-archive .wp-block-kadence-posts .entry-title a:hover{
	text-decoration: underline;
}

.author-podcast .wp-block-kadence-posts .loop-entry  {
	background-color: #2ACDB6;
}

.loop-podcast .wp-block-kadence-posts .loop-entry  {
	background-color: #BCB4DD;
}

.corridor-podcast .wp-block-kadence-posts .loop-entry  {
	background-color: #FFC549;
}

.kb-buttons-wrap{
	  white-space: nowrap;
  
}

.pc-max-width{

	max-width: 1166px;
	margin: 0 auto;
}

.podcast-archive .wp-block-kadence-posts .loop-entry .entry-content-wrap {
    padding: 20px 0;
}

.podcast-archive .entry-meta {
	color: white;
	font-weight: 500;
	font-size: 20px;
}
.podcast-archive .entry-summary{
	font-size: 20px;
}

.single-entry-content img {
  width: 100%;
  max-width: 540px;
  display: block;
  margin: 0px auto !important;
    margin-right: auto;
