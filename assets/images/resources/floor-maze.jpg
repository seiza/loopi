<style>
@media (max-width: 1200px) {
    :root {
        --content-width: calc(100vw - 40px);
    }
}
:root{
    --header-height: 376px;  
    --plate-width: 430px;
    --content-width: clamp(1050px, calc(100vw - 860px), 1350px);
}

@media (min-width: 1000px) {
.main .container,
.main.container {
    max-width: var(--content-width) !important;
    margin-left: auto !important;
    margin-right: auto !important;
}
.main {
    max-width: var(--content-width);
    margin-left: auto;
    margin-right: auto;
}

.header{ position: relative; width:100%; z-index:1000; }
}
#backing-plate{
    position: sticky;
    top: 0;
    /* top: 100%; */
    left: 0; right: 0;
    height: 0;
    pointer-events: none;
    z-index: 1;
}
#google_image_div {
    position: sticky !important;
    top: 0;
}

.auto-backing-plate{ position: relative; width:100%; height:0; }

.content_leftbar_ad,
.content_rightbar_ad{
    position: fixed;
    top: var(--header-height);
    width: var(--plate-width);
    pointer-events: auto;
    z-index: 999;
}

.content_leftbar_ad{
    left: calc(50% - (var(--content-width)/2) - var(--plate-width));
}
.content_rightbar_ad{
    right: calc(50% - (var(--content-width)/2) - var(--plate-width));
}

.backing-plate-tablet{
    position: fixed;
    top: var(--header-height);
    left: 50%;
    transform: translateX(-50%);
    width: 728px;
    z-index: 998;
    pointer-events: auto;
    display: none;
}

.top-catfish{
    display: none;
}

@media (max-width: 1299px) and (min-width: 680px){
    /* .backing-plate-tablet{
        display: block;
    } */
    .backing-plate-tablet{
    /* position: relative; 
    top: 42px;
    left: auto;
    transform: none;
    margin: 0 auto 20px;
    display: block; */
  }
  .top-catfish{
    display: block !important;
}
}

@media (max-width: 1299px){
    #backing-plate{ display:none; }
}

.header__main{
    z-index: 999;
}
.footer{
    z-index: 1050;
    margin-bottom: -30px;
}
</style>


<style>

.single-entry-content ul {
list-style-type: disc !important;
}
</style>
