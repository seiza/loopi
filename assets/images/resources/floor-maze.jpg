<script>
	$(document).ready(function() {
        var bpLeft = $('.content_leftbar_ad');
        var bpRight = $('.content_rightbar_ad');
        var bpTablet = $('.backing-plate-tablet');
        var headerNav = document.getElementById('headerNav');
        var billboard = document.querySelector('.banner-wrap.billboard');
        var billboardRetryTimer = null;
        var billboardRetryCount = 0;
        var maxBillboardRetries = 10;

        function getHeaderHeight() {
            console.log('getHeaderHeight');
            var value = getComputedStyle(document.documentElement).getPropertyValue('--header-height');
            var height = parseInt(value, 10);
            console.log('height', height);
            height += 30;
            return Number.isFinite(height) ? height : 376;
        }

        function refreshBillboardReference() {
            if (!billboard || !document.body.contains(billboard)) {
                billboard = document.querySelector('.banner-wrap.billboard');
            }
        }

        function getBillboardHeight() {
            refreshBillboardReference();

            if (!billboard) return 0;
            var styles = getComputedStyle(billboard);
    
            var marginTop = parseInt(styles.marginTop, 10)|| 0;
            var marginBottom = parseInt(styles.marginBottom, 10) || 0;
            return billboard.offsetHeight + marginTop + marginBottom;
        }

        function scheduleBillboardRetry() {
            if (billboardRetryTimer) return;
            if (billboardRetryCount >= maxBillboardRetries) {

                return;
            }
            billboardRetryCount++;
            billboardRetryTimer = setTimeout(function() {
                billboardRetryTimer = null;
                var billboardHeight = getBillboardHeight();

                updateBackingPlates();
            }, 200);
        }

        function updateBackingPlates() {
            if (window.innerWidth <= 779) {
                bpLeft.css({ position: '', top: '' });
                bpRight.css({ position: '', top: '' });
                return; 
            }
console.log('updateBackingPlates');
            var scrollY = $(window).scrollTop();

            var headerHeight = headerNav ? headerNav.offsetHeight + 26 : getHeaderHeight();
            var billboardHeight = getBillboardHeight();
        
            
            if (!billboardHeight) {
                scheduleBillboardRetry();
            }
            
            var stickyTop = headerHeight + billboardHeight;
            var top = stickyTop - scrollY;
            if (top < 0) top = 0;

            bpLeft.css({ position: 'fixed', top: top + 'px' });
            bpRight.css({ position: 'fixed', top: top + 'px' });
        }

        setTimeout(updateBackingPlates, 1500);
        $(window).on('scroll resize', updateBackingPlates);
	});
</script>
